    "name": "Grubby",
    "semanticHighlighting": true,
    "semanticTokenColors": {
        "customLiteral": "#d5c4a1",
        "newOperator": "#d5c4a1",
        "numberLiteral": "#8ec07c",
        "stringLiteral": "#b8bb26"
    },
    "tokenColors": [
        {
            "name": "remove highlights",
            "scope": [
                "entity.name.variable"
            ],
            "settings": {
                "foreground": "#d5c4a1"
            }
        },
        {
            "name": "Comments",
            "scope": [
                "comment",
                "punctuation.definition.comment"
            ],
            "settings": {
                "foreground": "#d65d0e"
            }
        },
        {
            "name": "Strings",
            "scope": [
                "string",
                "string.regexp",
                "constant.other.symbol"
            ],
            "settings": {
                "foreground": "#b8bb26"
            }
        },
        {
            "name": "Strings: Escape Sequences",
            "scope": "constant.character.escape",
            "settings": {
                "foreground": "#a89984"
            }
        },
        {
            "name": "Numbers, Characters",
            "scope": [
                "constant.numeric",
                "constant.character",
                "constant.keyword",
                "constant"
            ],
            "settings": {
                "foreground": "#83a598"
            }
        },
        {
            "name": "Global definitions",
            "scope": "entity.name,support.function",
            "settings": {
                "foreground": "#fabd2f"
            }
        },
        {
            "name": "Punctuation",
            "scope": "punctuation,meta.brace",
            "settings": {
                "foreground": "#a89984"
            }
        },
        {
            "name": "Invalid",
            "scope": "invalid",
            "settings": {
                "foreground": "#cc241d"
            }
        }
    ]
}